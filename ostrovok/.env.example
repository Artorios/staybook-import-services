# database
POSTGRES_DB=hotels
POSTGRES_USER=user
POSTGRES_PASSWORD=passpass
POSTGRES_PORT=5432

# debezium / cdc → kafka (main-flatform/stage/kafka)
KAFKA_BOOTSTRAP_SERVERS=kafka-1:9092
DEBEZIUM_USER=debezium
DEBEZIUM_PASSWORD=debezium_pass
DEBEZIUM_SLOT_NAME=debezium
DEBEZIUM_PUBLICATION=dbz_publication
DEBEZIUM_TOPIC_PREFIX=ostrovok
DEBEZIUM_CONNECTOR_NAME=ostrovok-postgres-connector
DEBEZIUM_GROUP_ID=ostrovok-debezium
DEBEZIUM_CONFIG_TOPIC=ostrovok_connect_configs
DEBEZIUM_OFFSET_TOPIC=ostrovok_connect_offsets
DEBEZIUM_STATUS_TOPIC=ostrovok_connect_status
DEBEZIUM_CONNECT_PORT=8083
# heap для Connect: ~300k отелей с крупным JSON в data
DEBEZIUM_HEAP_OPTS=-Xms1g -Xmx6g

# app
BATCH_SIZE=500
# макс. размер одной NDJSON-строки в байтах (по умолчанию 16 МБ)
MAX_LINE_SIZE=16777216
