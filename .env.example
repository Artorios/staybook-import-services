# database (shared across import-service providers)
POSTGRES_DB=hotels
POSTGRES_USER=user
POSTGRES_PASSWORD=passpass
POSTGRES_PORT=5433

# debezium / cdc → kafka (main-flatform/stage/kafka)
KAFKA_BOOTSTRAP_SERVERS=kafka-1:9092
DEBEZIUM_USER=debezium
DEBEZIUM_PASSWORD=debezium_pass
DEBEZIUM_SLOT_NAME=debezium
DEBEZIUM_PUBLICATION=dbz_publication
DEBEZIUM_TOPIC_PREFIX=import-service
DEBEZIUM_CONNECTOR_NAME=import-service-postgres-connector
DEBEZIUM_GROUP_ID=import-service-debezium
DEBEZIUM_CONFIG_TOPIC=import_service_connect_configs
DEBEZIUM_OFFSET_TOPIC=import_service_connect_offsets
DEBEZIUM_STATUS_TOPIC=import_service_connect_status
DEBEZIUM_CONNECT_PORT=8083
# heap для Connect: ~300k отелей с крупным JSON в data
DEBEZIUM_HEAP_OPTS=-Xms1g -Xmx6g
